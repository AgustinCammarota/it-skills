---
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import Calendly from "@components/Calendly.svelte";
import ContactForm from "@components/ContactForm.svelte";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="contact-section">
  <div class="form-container">
    <h2 class="form-title">{t("contact.form.title")}</h2>
    <ContactForm currentUrl={Astro.url} client:only="svelte" />
  </div>

  <div class="calendly-container">
    <Calendly client:only="svelte" />
  </div>
</section>

<style>
  .contact-section {
    width: 100%;
    height: 100%;
    display: flex;
    padding: 24px 16px;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 16px;
  }
  .form-container {
    height: 100%;
    width: 100%;
    max-width: 500px;
    min-width: 300px;
    padding: 16px 24px;
    margin-bottom: 24px;
    background-color: var(--lightest-color);
    border-radius: 8px;
  }
  .form-title {
    margin-top: 12px;
    margin-bottom: 42px;
    color: var(--darker-color);
    font-weight: bold;
    text-align: center;
    text-wrap: balance;
    line-height: var(--fs-xl);
  }
  .calendly-container {
    width: 100%;
    max-width: 500px;
    min-width: 300px;
    height: 100%;
  }

  @media (width >= 768px) {
    .contact-section {
      margin: 64px 0;
      padding: 0;
      flex-direction: row;
      align-items: start;
    }
    .form-container {
      height: 605px;
      margin: 12px 16px;
    }
    .calendly-container {
      padding: 12px;
      max-width: 600px;
    }
  }
</style>
