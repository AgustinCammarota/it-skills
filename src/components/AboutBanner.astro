---
import { getRelativeLocaleUrl } from "astro:i18n";
import CustomImage from "@components/CustomImage.astro";

interface Props {
  title: string;
  subtitle?: string;
  link: string;
  href: string;
  imagePath: string;
  altText: string;
  lang: string;
}

const {
  title,
  subtitle = "",
  link,
  href,
  imagePath,
  altText,
  lang,
} = Astro.props;
---

<section class="about-banner-section">
  <div class="about-banner-container">
    <div class="about-banner-content">
      <h1 class="about-banner-title">
        {title}
      </h1>
      <h2 class="about-banner-subtitle gradient-title">
        {subtitle}
      </h2>
      <div class="about-banner-description">
        <slot />
      </div>
      <a
        class="about-banner-link"
        href={getRelativeLocaleUrl(lang, href)}
        title={link}
      >
        {link}
      </a>
    </div>
  </div>

  <div class="about-background-image" aria-hidden="true">
    <CustomImage
      className="background-image"
      imagePath={imagePath}
      altText={altText}
      layout="constrained"
      quality="max"
      isPriority
    />
  </div>
</section>

<style>
  .about-banner-section {
    width: 100%;
    position: relative;
  }
  .about-banner-container {
    width: 100%;
    height: auto;
  }
  .about-banner-content {
    width: 100%;
    height: auto;
    padding: 48px 24px;
    background-color: rgb(242 245 255 / 65%);
  }
  .about-banner-title {
    margin: 0;
    line-height: 34px;
    color: var(--darkest-color);
    text-wrap: balance;
  }
  .about-banner-subtitle {
    margin: 24px 0;
    font-style: italic;
  }
  .about-banner-description {
    text-wrap: wrap;
    font-weight: 200;

    p {
      color: var(--dark-color);
    }

    ul {
      list-style: none;
      padding-left: 0;
    }

    ul li {
      color: var(--dark-color);
      position: relative;
      padding-left: 1.5em;
      margin-bottom: 0.75em;
      transition: color 0.3s;
    }

    ul li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.4em;
      width: 0.6em;
      height: 0.6em;
      background-color: var(--dark-color);
      border-radius: 50%;
    }
  }
  .about-banner-link {
    display: inline-block;
    margin-top: 12px;
    padding: 8px 16px;
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      var(--light-color),
      var(--primary-color),
      var(--dark-color)
    );
    color: var(--lightest-color);
    font-weight: 600;
  }
  .about-background-image {
    width: 100%;
    height: 100%;
    position: absolute;
    z-index: -1;
    top: 0;
    left: 0;
  }

  @media (width >= 768px) {
    .about-banner-section {
      min-height: 600px;
      padding: 40px;
    }
    .about-banner-content {
      width: 570px;
      border-radius: 12px;
    }
    .about-banner-container {
      max-width: 1800px;
      margin: 0 auto;
    }
    .about-banner-link:hover {
      background: linear-gradient(
        270deg,
        var(--lightest-color),
        var(--lighter-color),
        var(--light-color)
      );
      color: var(--darkest-color);
    }
  }
</style>
