---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  imagePath: string;
  altText: string;
  width?: number;
  height?: number;
  className?: string;
  layout?: "none" | "fixed" | "constrained" | "full-width";
  loading?: "eager" | "lazy" | null | undefined;
  quality?: "low" | "mid" | "high" | "max";
}

const {
  imagePath,
  altText,
  width,
  height,
  className = "",
  layout = "none",
  loading = "lazy",
  quality = "low",
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp}",
);
if (!images[imagePath]) {
  throw new Error(
    'Path does not exist in glob: "src/assets/images/*.{jpeg,jpg,png,gif,webp}',
  );
}
---

<Image
  class={className}
  src={images[imagePath]()}
  width={width}
  height={height}
  loading={loading}
  title={altText}
  alt={altText}
  quality={quality}
  layout={layout}
  fit="cover"
  position="center"
/>
<style>
  .background-image {
    width: 100%;
    height: 100%;
  }
  .rounded {
    border-radius: 50%;
  }
</style>
